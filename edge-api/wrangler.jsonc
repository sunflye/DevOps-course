    "compatibility_date": "2026-05-09",
    "vars": {
        "API_VERSION": "v1.1.0"
    },
    "kv_namespaces": [
        {
            "binding": "EDGE_KV",
            "id": "1600409be4814f9aaf1a48fafbb7b263"
        }
    ]
}